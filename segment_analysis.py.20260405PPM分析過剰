class SegmentHierarchyResolver:
    """Service to discover and reorder segment columns hierarchically."""
    OTHER_KW = ["その他", "以外", "Other", "Others"]
    ADJ_KW   = ["調整", "消去", "内部", "Adjustment", "Elimination"]
    TOTAL_HOKOKU_KW = ["報告セグメント", "報告セグメント合計", "Reportable segments", "Total reportable segments"]
    TOTAL_HOKOKU_OTHER_KW = [
        "報告セグメント及びその他の合計", "報告セグメント及びその他事業の合計", 
        "Total of reportable segments and other segments", "Total of reportable segments and others"
    ]
    GRAND_TOTAL_KW = ["全体", "全体合計", "連結", "Consolidated", "Total"]

    def __init__(self, debug_log):
        self.debug_log = debug_log

    def _normalize(self, text: Any) -> str:
        if text is None: return ""
        return unicodedata.normalize('NFKC', str(text)).strip().lower()

    def resolve(self, ws, strategy: PPMStrategy) -> ColumnMap:
        max_col = ws.max_column
        total_rows = ws.max_row
        all_col_data = []

        for ci in range(3, max_col + 1):
            header = ws.cell(1, ci).value
            norm_h = self._normalize(header)
            cat = "reporting"
            
            if any(self._normalize(kw) == norm_h for kw in self.TOTAL_HOKOKU_OTHER_KW): cat = "xbrl_hokoku_other_total"
            elif any(self._normalize(kw) == norm_h for kw in self.TOTAL_HOKOKU_KW): cat = "xbrl_hokoku_total"
            elif any(self._normalize(kw) == norm_h for kw in self.GRAND_TOTAL_KW): cat = "xbrl_grand_total"
            elif any(self._normalize(kw) in norm_h for kw in self.ADJ_KW): cat = "adj"
            elif any(self._normalize(kw) in norm_h for kw in self.OTHER_KW): cat = "other"
            
            data = [ws.cell(ri, ci).value for ri in range(2, total_rows + 1)]
            all_col_data.append({"header": header, "cat": cat, "data": data})

        for ci in range(max_col, 2, -1): ws.delete_cols(ci)
        
        next_col = 3
        def _add(h, d=None, f=None):
            nonlocal next_col
            idx = next_col
            ws.cell(1, idx).value = h
            if d:
                for i, v in enumerate(d): ws.cell(i + 2, idx).value = v
            elif f:
                for r in range(2, total_rows + 1): ws.cell(r, idx).value = f(r)
            next_col += 1
            return idx

        reps = [c for c in all_col_data if c["cat"] == "reporting"]
        others = [c for c in all_col_data if c["cat"] == "other"]
        adjs = [c for c in all_col_data if c["cat"] == "adj"]
        x_hok_tot = next((c for c in all_col_data if c["cat"] == "xbrl_hokoku_total"), None)
        x_hok_oth = next((c for c in all_col_data if c["cat"] == "xbrl_hokoku_other_total"), None)

        if not reps:
            raise ColumnNotFoundError("No reporting segment columns found.")

        rep_idx = [_add(c["header"], c["data"]) for c in reps]
        if x_hok_tot: hokoku_idx = _add(x_hok_tot["header"], x_hok_tot["data"])
        else:
            c1, c2 = get_column_letter(rep_idx[0]), get_column_letter(rep_idx[-1])
            hokoku_idx = _add("報告セグメント合計(計算値)", f=lambda r: f"=SUM({c1}{r}:{c2}{r})")
        
        oth_idx = [_add(c["header"], c["data"]) for c in others]
        if x_hok_oth: goukei_idx = _add(x_hok_oth["header"], x_hok_oth["data"])
        else:
            p = [get_column_letter(hokoku_idx)] + [get_column_letter(i) for i in oth_idx]
            goukei_idx = _add("報告セグメント及びその他の合計(計算値)", f=lambda r: "=SUM(" + ",".join([f"{x}{r}" for x in p]) + ")")
        
        adj_idx = [_add(c["header"], c["data"]) for c in adjs]
        g = [get_column_letter(goukei_idx)] + [get_column_letter(i) for i in adj_idx]
        grand_idx = _add("全社(計算値)", f=lambda r: "=SUM(" + ",".join([f"{x}{r}" for x in g]) + ")")
        
        for c in [x for x in all_col_data if x["cat"].startswith("xbrl_")]: _add(c["header"] + "(既存)", c["data"])
        return ColumnMap(hokoku=hokoku_idx, other=oth_idx, goukei=goukei_idx, grand_total=grand_idx)

class PLFallbackService:
    """Service to handle fallback values from Statement of Income."""
    def get_value(self, workbook, metric_type: str, period: str, current_val: Any) -> Any:
        if current_val not in [None, "", 0]: return current_val
        val = _fetch_pl_value(workbook, metric_type, period)
        return val if val else current_val

class PPMMetricsCalculator:
    """Service to calculate and append PPM rows."""
    def __init__(self, fallback_service: PLFallbackService):
        self.fallback = fallback_service

    def append_data_rows(self, ws, amap, workbook, valid_pairs, strategy, label, period_lookup, analysis_ws, metric_type):
        start_row = ws.max_row + 1
        seg_offset = 2
        col_to_dim = {c: str(analysis_ws.cell(1, c).value) for c in range(3, analysis_ws.max_column + 1)}
        igai_col = amap.other[-1] if amap.other else None
        get_val = _make_get_val_for_filing(analysis_ws, col_to_dim, amap.hokoku, igai_col, amap.goukei, True, True)

        for fp in valid_pairs:
            cur_p, pri_p = fp['current'], fp['prior']
            cur_src = period_lookup.get((label, cur_p))
            pri_src = period_lookup.get((label, pri_p)) if pri_p else None
            
            pri_r, cur_r = ["　" + label, cur_p, "前期", pri_p or ""], ["　" + label, cur_p, "当期", cur_p]
            for c in range(3, analysis_ws.max_column + 1):
                pri_r.append(get_val(pri_src, c, fp, False) if pri_src else "")
                cur_r.append(get_val(cur_src, c, fp, True) if cur_src else "")
            
            idx = amap.grand_total + seg_offset - 1
            cur_r[idx] = self.fallback.get_value(workbook, metric_type, cur_p, cur_r[idx])
            if pri_p: pri_r[idx] = self.fallback.get_value(workbook, metric_type, pri_p, pri_r[idx])

            ws.append(pri_r); ws.append(cur_r)
        return start_row, ws.max_row

    def append_metric_rows(self, ws, sales_start, profit_start, valid_pairs, max_col, title, is_growth=True):
        start_row = ws.max_row + 1
        seg_offset = 2
        base_p = valid_pairs[0]['prior']
        ws.append([title, base_p or "", "", base_p or ""] + [""] * (max_col - 2))
        
        for i, fp in enumerate(valid_pairs):
            cur_p = fp['current']
            r1 = sales_start + 2*i if is_growth else sales_start + 2*i + 1
            r2 = sales_start + 2*i + 1 if is_growth else profit_start + 2*i + 1
            row = [title, cur_p, "", cur_p]
            for c in range(3, max_col + 1):
                cl = get_column_letter(c + seg_offset)
                if is_growth:
                    row.append(f"=IF(OR({cl}{r1}=\"\",{cl}{r2}=\"\"),\"\",{cl}{r2}/{cl}{r1}-1)")
                else:
                    row.append(f"=IF(OR({cl}{r1}=\"\",{cl}{r2}=\"\"),\"\",{cl}{r2}/{cl}{r1})")
            ws.append(row)
        return start_row, ws.max_row

class PPMChartBuilder:
    """Service to aggregate chart data and render bubble charts."""
    def build_data_area(self, ws, amap, filing_idx, start_row, valid_pairs, sales_start, growth_start, margin_start, label):
        col_year, col_data, seg_offset = 4, 5, 2
        cur_p = valid_pairs[filing_idx]['current']
        cur_s, g_row, m_row = sales_start + 2*filing_idx + 1, growth_start + filing_idx + 1, margin_start + filing_idx + 1
        vcols = list(range(3, amap.hokoku + 1))
        
        ws.cell(start_row, col_year).value = cur_p
        for k, ci in enumerate(vcols):
            ws.cell(start_row, col_data + k).value = f"={get_column_letter(ci + seg_offset)}1"
        ws.cell(start_row, col_data + vcols.index(amap.hokoku)).value = "計"
        ws.cell(start_row + 1, col_year).value = "利益率"
        for k, ci in enumerate(vcols): ws.cell(start_row + 1, col_data + k).value = f"={get_column_letter(ci + seg_offset)}{m_row}"
        ws.cell(start_row + 2, col_year).value = "増加率"
        for k, ci in enumerate(vcols): ws.cell(start_row + 2, col_data + k).value = f"={get_column_letter(ci + seg_offset)}{g_row}"
        ws.cell(start_row + 3, col_year).value = label
        for k, ci in enumerate(vcols):
            cl = get_column_letter(ci + seg_offset)
            ws.cell(start_row + 3, col_data + k).value = f"={cl}{cur_s}*1%" if ci == amap.hokoku else f"={cl}{cur_s}"
        
        for k in range(len(vcols)):
            cl = get_column_letter(col_data + k)
            ws[f'{cl}{start_row + 1}'].number_format = '0%'
            ws[f'{cl}{start_row + 2}'].number_format = '0%'
            ws[f'{cl}{start_row + 3}'].number_format = '#,##0'
        return start_row, start_row + 3, col_data + len(vcols) - 1

    def render(self, ws, title, data_info, pos):
        s_row, e_row, max_c = data_info
        chart = BubbleChart()
        chart.title = title
        chart.x_axis.title, chart.y_axis.title = "売上高利益率", "売上高対前年増加率"
        x = Reference(ws, 5, s_row + 1, max_c, s_row + 1)
        y = Reference(ws, 5, s_row + 2, max_c, s_row + 2)
        z = Reference(ws, 5, s_row + 3, max_c, s_row + 3)
        chart.series.append(Series(values=y, xvalues=x, zvalues=z))
        ws.add_chart(chart, pos)

class PPMAnalysisEngine:
    """Enterprise Orchestrator for PPM Analysis (DI Architecture)."""
    def __init__(self, strategy: PPMStrategy, resolver: SegmentHierarchyResolver, 
                 calculator: PPMMetricsCalculator, builder: PPMChartBuilder, debug_log):
        self.strategy = strategy
        self.resolver = resolver
        self.calculator = calculator
        self.builder = builder
        self.debug_log = debug_log

    def run(self, workbook, analysis_ws, ppm_ws, filing_pairs):
        try:
            amap = self.resolver.resolve(analysis_ws, self.strategy)
            period_lookup, unique_labels = _build_period_lookup(analysis_ws)
            
            s_lab = next((l for l in unique_labels if any(k in l for k in self.strategy.sales_keywords)), self.strategy.sales_label_default)
            p_lab = next((l for l in unique_labels if any(k in l for k in self.strategy.profit_keywords)), "セグメント利益")
            
            valid_pairs = []
            for fp in filing_pairs:
                cp, pp = _to_period_str(fp.get('current')), _to_period_str(fp.get('prior'))
                if cp: valid_pairs.append({'current': cp, 'prior': pp})
            if not valid_pairs: return
            valid_pairs = valid_pairs[-11:]
            
            ppm_ws.append(["勘定科目", "報告年度", "前期・当期", "会計年度"] + [analysis_ws.cell(1, c).value for c in range(3, analysis_ws.max_column + 1)])
            s_start, s_end = self.calculator.append_data_rows(ppm_ws, amap, workbook, valid_pairs, self.strategy, s_lab, period_lookup, analysis_ws, "sales")
            ppm_ws.append([])
            p_start, p_end = self.calculator.append_data_rows(ppm_ws, amap, workbook, valid_pairs, self.strategy, p_lab, period_lookup, analysis_ws, "profit")
            ppm_ws.append([])
            g_start, g_end = self.calculator.append_metric_rows(ppm_ws, s_start, p_start, valid_pairs, analysis_ws.max_column, "売上高対前年増加率", True)
            ppm_ws.append([])
            m_start, m_end = self.calculator.append_metric_rows(ppm_ws, s_start, p_start, valid_pairs, analysis_ws.max_column, "売上高利益率", False)
            
            ppm_ws.freeze_panes = 'B2'
            ppm_ws.column_dimensions['A'].width = 31
            
            lat_idx = len(valid_pairs) - 1
            lat_info = self.builder.build_data_area(ppm_ws, amap, lat_idx, ppm_ws.max_row + 2, valid_pairs, s_start, g_start, m_start, s_lab)
            self.builder.render(ppm_ws, f"PPM分析 {valid_pairs[lat_idx]['current']} {self.strategy.chart_title_suffix}", lat_info, f'B{ppm_ws.max_row + 2}')
            
            if len(valid_pairs) > 5:
                fv_idx = len(valid_pairs) - 6
                fv_info = self.builder.build_data_area(ppm_ws, amap, fv_idx, ppm_ws.max_row + 2, valid_pairs, s_start, g_start, m_start, s_lab)
                self.builder.render(ppm_ws, f"PPM分析 {valid_pairs[fv_idx]['current']} {self.strategy.chart_title_suffix}", fv_info, f'I{lat_info[0]}')
        except PPMError as e:
            self.debug_log(f"[PPM Engine] Error: {str(e)}")

def _create_ppm_analysis_sheet(workbook, analysis_sheet_name, used_sheet_names, filing_pairs, debug_log):
    """
    PPM分析シートを作成（日本基準）
    """
    ppm_sheet_name = analysis_sheet_name + "_PPM分析用"
    if len(ppm_sheet_name) > 31:
        ppm_sheet_name = analysis_sheet_name[:18] + "_PPM分析用"
    
    if analysis_sheet_name not in workbook.sheetnames:
        return
    
    analysis_ws = workbook[analysis_sheet_name]
    ppm_ws = workbook.create_sheet(title=ppm_sheet_name)
    used_sheet_names.add(ppm_sheet_name)

    # Dependency Injection
    strategy = JPGAAPStrategy()
    resolver = SegmentHierarchyResolver(debug_log)
    fallback = PLFallbackService()
    calculator = PPMMetricsCalculator(fallback)
    builder = PPMChartBuilder()
    
    engine = PPMAnalysisEngine(strategy, resolver, calculator, builder, debug_log)
    engine.run(workbook, analysis_ws, ppm_ws, filing_pairs)

    debug_log(f"[PPM Analysis] Completed JP GAAP PPM sheet: {ppm_sheet_name}")


    all_col_data = []
    total_rows = analysis_ws.max_row
    for _ci in range(3, max_col + 1):
        header = analysis_ws.cell(1, _ci).value
        cat = _get_category_strict(header)
        data = [analysis_ws.cell(_ri, _ci).value for _ri in range(2, total_rows + 1)]
        all_col_data.append({"header": header, "cat": cat, "data": data})

    def _sum_data(data_list):
        s = 0.0
        has_val = False
        for v in data_list:
            if isinstance(v, (int, float)):
                s += v
                has_val = True
        return s if has_val else None

    rep_cols = [c for c in all_col_data if c["cat"] == "reporting"]
    other_cols = [c for c in all_col_data if c["cat"] == "other"]
    adj_cols = [c for c in all_col_data if c["cat"] == "adj"]
    xbrl_hok_tot = next((c for c in all_col_data if c["cat"] == "xbrl_hokoku_total"), None)
    xbrl_hok_oth = next((c for c in all_col_data if c["cat"] == "xbrl_hokoku_other_total"), None)

    def _is_valid_total(xbrl_col, children_cols):
        if not xbrl_col: return False
        xbrl_sum = _sum_data(xbrl_col["data"])
        child_sum = sum((_sum_data(cc["data"]) or 0.0 for cc in children_cols))
        return xbrl_sum is not None and abs(xbrl_sum - child_sum) < 10

    # 重ね書き開始
    for _ci in range(max_col, 2, -1): analysis_ws.delete_cols(_ci)
    next_col = 3
    def _append_col(header, data=None, formula_type=None, formula_range=None):
        nonlocal max_col, next_col
        new_idx = next_col
        analysis_ws.cell(1, new_idx).value = header
        if data:
            for i, val in enumerate(data): analysis_ws.cell(i + 2, new_idx).value = val
        elif formula_type == "sum" and formula_range:
            cl1, cl2 = get_column_letter(formula_range[0]), get_column_letter(formula_range[1])
            for r in range(2, total_rows + 1): analysis_ws.cell(r, new_idx).value = f"=SUM({cl1}{r}:{cl2}{r})"
        elif formula_type == "sum_parts" and formula_range:
            parts = [get_column_letter(c) for c in formula_range]
            for r in range(2, total_rows + 1): analysis_ws.cell(r, new_idx).value = "=SUM(" + ",".join([f"{p}{r}" for p in parts]) + ")"
        max_col = new_idx; next_col += 1
        return new_idx

    rep_indiv_indices = [_append_col(c["header"], c["data"]) for c in rep_cols]
    hokoku_total_idx = None
    hokoku_other_total_idx = None

    if xbrl_hok_oth and _is_valid_total(xbrl_hok_oth, rep_cols + other_cols):
        hokoku_total_idx = _append_col("報告セグメント合計(計算値)")
        final_other_indices = [_append_col(c["header"], c["data"]) for c in other_cols]
        hokoku_other_total_idx = _append_col(xbrl_hok_oth["header"], xbrl_hok_oth["data"])
        total_cl = get_column_letter(hokoku_other_total_idx)
        if final_other_indices:
            oth_sum = "+".join([f"{get_column_letter(c)}" for c in final_other_indices])
            for r in range(2, total_rows + 1): analysis_ws.cell(r, hokoku_total_idx).value = f"={total_cl}{r}-({oth_sum})"
        else:
            for r in range(2, total_rows + 1): analysis_ws.cell(r, hokoku_total_idx).value = f"={total_cl}{r}"
    elif xbrl_hok_tot and _is_valid_total(xbrl_hok_tot, rep_cols):
        hokoku_total_idx = _append_col(xbrl_hok_tot["header"], xbrl_hok_tot["data"])
        final_other_indices = [_append_col(c["header"], c["data"]) for c in other_cols]
        hokoku_other_total_idx = _append_col("報告セグメント及びその他の合計(計算値)", formula_type="sum_parts", formula_range=[hokoku_total_idx]+final_other_indices)
    else:
        hokoku_total_idx = _append_col("報告セグメント合計(計算値)", formula_type="sum", formula_range=(rep_indiv_indices[0], rep_indiv_indices[-1])) if rep_indiv_indices else _append_col("報告セグメント合計(計算値)")
        final_other_indices = [_append_col(c["header"], c["data"]) for c in other_cols]
        hokoku_other_total_idx = _append_col("報告セグメント及びその他の合計(計算値)", formula_type="sum_parts", formula_range=[hokoku_total_idx]+final_other_indices)

    final_adj_indices = [_append_col(c["header"], c["data"]) for c in adj_cols]
    grand_total_idx = _append_col("全社(計算値)", formula_type="sum_parts", formula_range=[hokoku_other_total_idx] + final_adj_indices)

    for col in [c for c in all_col_data if c["cat"].startswith("xbrl_")]:
        _append_col(col["header"] + "(既存)", col["data"])

    hokoku_col, igai_col, goukei_col = hokoku_total_idx, (final_other_indices[-1] if final_other_indices else None), hokoku_other_total_idx
    chart_end_col = goukei_col

    # --- Data Retrieval ---
    def _has_data_row(row):
        if row is None: return False
        return any(isinstance(analysis_ws.cell(row, c).value, (int, float)) for c in range(3, analysis_ws.max_column + 1))

    def _get_profit_src(period_str):
        for candidate in profit_label_candidates:
            row = period_lookup.get((candidate, period_str))
            if row is not None and _has_data_row(row): return candidate, row
        return None, None

    valid_pairs = []
    for fp in filing_pairs:
        cur_p = _to_period_str(fp.get('current'))
        pri_p = _to_period_str(fp.get('prior'))
        if not cur_p: continue
        cur_s = period_lookup.get((target_sales_label, cur_p)) if target_sales_label else None
        _, cur_p_src = _get_profit_src(cur_p)
        if _has_data_row(cur_s) or _has_data_row(cur_p_src):
            valid_pairs.append({'current': cur_p, 'prior': pri_p, 'current_dims': fp.get('current_dims', set()), 'prior_dims': fp.get('prior_dims', set())})
    valid_pairs.sort(key=lambda fp: fp['current'] or '')
    if len(valid_pairs) > 11: valid_pairs = valid_pairs[-11:]
    N = len(valid_pairs)
    if N == 0:
        workbook.remove(ppm_ws); used_sheet_names.discard(ppm_sheet_name); return

    SEG_OFFSET = 2
    col_to_dim = {c: str(analysis_ws.cell(1, c).value) for c in range(3, max_col + 1) if analysis_ws.cell(1, c).value}
    _get_val_for_filing = _make_get_val_for_filing(analysis_ws, col_to_dim, hokoku_col, igai_col, goukei_col, True, True)

    ppm_ws.append(["勘定科目", "報告年度", "前期・当期", "会計年度"] + [analysis_ws.cell(1, c).value or "" for c in range(3, max_col + 1)])
    sales_start_row = ppm_ws.max_row + 1
    for i, fp in enumerate(valid_pairs):
        cur_p, pri_p = fp['current'], fp['prior']
        pri_src = period_lookup.get((target_sales_label, pri_p)) if (target_sales_label and pri_p) else None
        cur_src = period_lookup.get((target_sales_label, cur_p)) if target_sales_label else None
        
        pri_row = [sales_display_label, cur_p, "前期", pri_p or ""]
