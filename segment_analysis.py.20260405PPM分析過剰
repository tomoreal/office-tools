@dataclass
class ColumnMap:
    """Type-safe mapping of resolved column indices."""
    hokoku: int            # 報告セグメント合計
    other: List[int]       # その他事業 (複数前提)
    goukei: int            # 報告セグメント及びその他の合計
    grand_total: int       # 全社 (連結財務諸表数値)

