def _to_period_str(pv):
    """period セルの値を 'YYYY-MM-DD' 文字列に正規化する。"""
    if pv is None:
        return None
    if hasattr(pv, 'strftime'):
        return pv.strftime('%Y-%m-%d')
    return str(pv).strip()


def _read_numeric(ws, row, col):
    """
    セルの実数値を返す。
    SUM式セルの場合、Excelが評価前であっても独自に数式または範囲を解析して合算値を返す。
    """
    if row is None or col is None:
        return None
    cell = ws.cell(row, col)
    val = cell.value

    # 数値ならそのまま返す
    if isinstance(val, (int, float)):
        return val

    # SUM数式の場合の独自計算
    if isinstance(val, str) and val.startswith('=SUM('):
        import re
        # =SUM(A1:B1) または =SUM(A1,B1,C1) の形式を抽出
        content = val[5:-1]
        total = 0.0
        has_val = False
        
        # カンマで区切られたパーツ（範囲または単一セル）を処理
        parts = content.split(',')
        for part in parts:
            if ':' in part:
                # 範囲形式: A1:C1
                try:
                    start_cell, end_cell = part.split(':')
                    # 列文字のみを抽出して数値に変換 (行は row を固定で使用)
                    start_col = column_index_from_string(re.sub(r'\d+', '', start_cell))
                    end_col = column_index_from_string(re.sub(r'\d+', '', end_cell))
                    for c in range(start_col, end_col + 1):
                        v = _read_numeric(ws, row, c)
                        if v is not None:
                            total += v
                            has_val = True
                except Exception:
                    continue
            else:
                # 単一セル形式: A1
                try:
                    c = column_index_from_string(re.sub(r'\d+', '', part))
                    # 自分自身を指している場合はスキップ（無限ループ防止）
                    if c == col:
                        continue
                    v = _read_numeric(ws, row, c)
                    if v is not None:
                        total += v
                        has_val = True
                except Exception:
                    continue
        return total if has_val else None

    return None


def _build_period_lookup(analysis_ws):
    """analysis_ws から (label, period_str) -> 行番号 の辞書と
    登場順ラベルリストを構築して返す。

    Returns:
        (period_lookup, unique_labels_ordered)
    """
    unique_labels_ordered = []
    period_lookup = {}
    for r in range(2, analysis_ws.max_row + 1):
        label_val = analysis_ws.cell(r, 1).value
        period_val = analysis_ws.cell(r, 2).value
        if not label_val:
            continue
        norm_label = str(label_val).strip()
        if not unique_labels_ordered or unique_labels_ordered[-1] != norm_label:
            unique_labels_ordered.append(norm_label)
        ps = _to_period_str(period_val)
        if ps:
            period_lookup[(norm_label, ps)] = r
    return period_lookup, unique_labels_ordered


def _build_col_info(analysis_ws, max_col):
    """analysis_ws のヘッダー行からセグメント列情報を構築して返す。

    Returns:
        (col_to_dim, hokoku_col, igai_col, goukei_col,
         hokoku_is_synthesized, goukei_is_synthesized)
    """
    col_to_dim = {}
    for c in range(3, max_col + 1):
        hv = analysis_ws.cell(1, c).value
        if hv is not None:
            col_to_dim[c] = str(hv)

    hokoku_col = next((c for c, d in col_to_dim.items() if d == '報告セグメント合計'), None)
    igai_col   = next((c for c, d in col_to_dim.items()
                       if '以外' in d and '報告セグメント' in d), None)
    goukei_col = next((c for c, d in col_to_dim.items()
                       if '報告セグメント及びその他の合計' in d), None)
    hokoku_is_synthesized = (col_to_dim.get(hokoku_col, '') == '報告セグメント合計')
    goukei_is_synthesized = (goukei_col is not None and
                              col_to_dim.get(goukei_col, '') == '報告セグメント及びその他の合計')
    return col_to_dim, hokoku_col, igai_col, goukei_col, hokoku_is_synthesized, goukei_is_synthesized


def _make_get_val_for_filing(analysis_ws, col_to_dim,
                              hokoku_col, igai_col, goukei_col,
                              hokoku_is_synthesized, goukei_is_synthesized):
    """_get_val_for_filing クロージャを生成して返す。"""
    def _get_val_for_filing(src_row, c, fp, is_current):
        if src_row is None: return None
        allowed = fp.get('current_dims', set()) if is_current else fp.get('prior_dims', set())
        if c in (hokoku_col, goukei_col):
            if not allowed:
                v = _read_numeric(analysis_ws, src_row, c)
                if v is not None: return v
        if c == hokoku_col and hokoku_is_synthesized:
            total, has_val = 0.0, False
            for cc in range(3, hokoku_col):
                if cc in (igai_col, goukei_col): continue
                dim = col_to_dim.get(cc, '')
                if allowed and dim not in allowed: continue
                v = _read_numeric(analysis_ws, src_row, cc)
                if v is not None:
                    total += v
                    has_val = True
            return total if has_val else None
        if c == goukei_col and goukei_is_synthesized:
            v_h = (_get_val_for_filing(src_row, hokoku_col, fp, is_current)
                   if (hokoku_col and hokoku_col != goukei_col) else None)
            v_between, has_between = 0.0, False
            if hokoku_col and goukei_col:
                for _bc in range(hokoku_col + 1, goukei_col):
                    if _bc == igai_col: continue
                    _bdim = col_to_dim.get(_bc, '')
                    if allowed and _bdim not in allowed: continue
                    _bv = _read_numeric(analysis_ws, src_row, _bc)
                    if _bv is not None:
                        v_between += _bv
                        has_between = True
            v_i = None
            if igai_col:
                igai_dim = col_to_dim.get(igai_col, '')
                if not allowed or igai_dim in allowed:
                    v_i = _read_numeric(analysis_ws, src_row, igai_col)
            if v_h is None and not has_between and v_i is None: return None
            return (v_h or 0.0) + v_between + (v_i or 0.0)
        dim = col_to_dim.get(c, '')
        if allowed and dim not in allowed: return None
        return _read_numeric(analysis_ws, src_row, c)
    return _get_val_for_filing


def _create_data_acquisition_sheet(workbook, analysis_sheet_name, used_sheet_names,
                                  filing_pairs, debug_log, global_element_period_values=None):
    """
    データ取得シートを作成（内部関数）
    """
    from openpyxl.utils import get_column_letter

    acq_sheet_name = "_データ取得"
    debug_log(f"[Data Acquisition] Starting creation for: {acq_sheet_name}")

    if analysis_sheet_name not in workbook.sheetnames:
        debug_log(f"[Data Acquisition] Analysis sheet '{analysis_sheet_name}' not found, skipping")
        return None, None, None

    analysis_ws = workbook[analysis_sheet_name]
    
    # 1. ヘッダー情報の抽出 (分析シートの1行目をベースにする)
    seg_headers = []
    included_cols = []
    for col_idx in range(3, analysis_ws.max_column + 1):
        h_val = analysis_ws.cell(1, col_idx).value
        if h_val:
            seg_headers.append(h_val)
            included_cols.append(col_idx)

    # 2. period_lookup と unique_labels_ordered 構築
    period_lookup, unique_labels_ordered = _build_period_lookup(analysis_ws)
    if not unique_labels_ordered:
        debug_log("[Data Acquisition] Analysis sheet has no data rows, skipping")
        return None, None, None

    ppm_data_memo = {"sales": [], "profit": []}

    # 2b. ラベルグループ化
    canonical_to_aliases = {}
    label_to_canonical = {}
    for lbl in unique_labels_ordered:
        if lbl in label_to_canonical: continue
        matched_canon = None
        for canon in list(canonical_to_aliases.keys()):
            if lbl.startswith(canon) or canon.startswith(lbl):
                matched_canon = canon
                break
        if matched_canon:
            canonical_to_aliases[matched_canon].append(lbl)
            label_to_canonical[lbl] = matched_canon
        else:
            canonical_to_aliases[lbl] = [lbl]
            label_to_canonical[lbl] = lbl

    unique_canonicals_ordered = []
    _seen_canon = set()
    for lbl in unique_labels_ordered:
        canon = label_to_canonical[lbl]
        if canon not in _seen_canon:
            unique_canonicals_ordered.append(canon)
            _seen_canon.add(canon)

    # 3. 新規シート作成
    if acq_sheet_name in workbook.sheetnames:
        workbook.remove(workbook[acq_sheet_name])
    acq_ws = workbook.create_sheet(title=acq_sheet_name)
    used_sheet_names.add(acq_sheet_name)

    acq_ws.append(["勘定科目", "報告年度", "前期・当期", "会計年度"] + seg_headers)

    # 4. データ展開
    col_info = _build_col_info(analysis_ws, analysis_ws.max_column)
    col_to_dim, hokoku_col, igai_col, goukei_col, hokoku_is_synthesized, goukei_is_synthesized = col_info
    _get_val_for_filing = _make_get_val_for_filing(
        analysis_ws, col_to_dim, hokoku_col, igai_col, goukei_col,
        hokoku_is_synthesized, goukei_is_synthesized)

    zentai_idx = next((i for i, h in enumerate(seg_headers) if str(h) == "全体" or str(h) == "連結"), None)
    hokoku_total_idx = next((i for i, h in enumerate(seg_headers) if str(h) == "報告セグメント合計"), None)
    igai_zen_idx = next((i for i, h in enumerate(seg_headers) if "報告セグメント以外の全てのセグメント" in str(h)), None)
    goukei_total_idx = next((i for i, h in enumerate(seg_headers) if "報告セグメント及びその他の合計" in str(h)), None)

    row_count = 0
    curr_row = 2
    for label in unique_canonicals_ordered:
        aliases = canonical_to_aliases.get(label, [label])
        for fp in filing_pairs:
            cur_p = _to_period_str(fp.get('current'))
            pri_p = _to_period_str(fp.get('prior'))
            if not cur_p: continue

            for flag, ps in [("前期", pri_p), ("当期", cur_p)]:
                row_data = [label, cur_p, flag, ps if ps else ""]
                is_curr = (flag == "当期")

                src_row = None
                if ps:
                    for ali in aliases:
                        r = period_lookup.get((ali, ps))
                        if r is not None:
                            src_row = r
                            break

                for i, c in enumerate(included_cols):
                    if zentai_idx is not None and i == zentai_idx:
                        if goukei_total_idx is not None and goukei_total_idx < zentai_idx:
                            f_cl = get_column_letter(5 + goukei_total_idx)
                            l_cl = get_column_letter(5 + zentai_idx - 1)
                            row_data.append(f'=IF(COUNT({f_cl}{curr_row}:{l_cl}{curr_row})=0,"",SUM({f_cl}{curr_row}:{l_cl}{curr_row}))')
                        else: row_data.append("")
                    elif goukei_total_idx is not None and i == goukei_total_idx:
                        v_xbrl = _get_val_for_filing(src_row, c, fp, is_curr) if (src_row is not None and c >= 0) else None
                        if v_xbrl is not None:
                            row_data.append(v_xbrl)
                        elif hokoku_total_idx is not None and igai_zen_idx is not None:
                            h_cl = get_column_letter(5 + hokoku_total_idx)
                            i_cl = get_column_letter(5 + igai_zen_idx)
                            row_data.append(f'=IF(AND({h_cl}{curr_row}="",{i_cl}{curr_row}=""),"",SUM({h_cl}{curr_row}:{i_cl}{curr_row}))')
                        else: row_data.append("")
                    else:
                        v = _get_val_for_filing(src_row, c, fp, is_curr) if (src_row is not None and c >= 0) else None
                        row_data.append(v if v is not None else "")

                acq_ws.append(row_data)

                # PPM捕捉
                is_sl = (label == "計" or "売上収益" in label or "営業収益" in label or "売上高" in label)
                is_pr = ("利益" in label or "損失" in label or "純益" in label)
                if is_sl: ppm_data_memo["sales"].append(row_data)
                if is_pr: ppm_data_memo["profit"].append(row_data)

                curr_row += 1
                row_count += 1
        acq_ws.append([])
        curr_row += 1

    # 定裁
    acq_ws.freeze_panes = 'E2'
    acq_ws.column_dimensions['A'].width = 31
    for c_idx in range(5, acq_ws.max_column + 1):
        acq_ws.column_dimensions[get_column_letter(c_idx)].width = 12

    return seg_headers, included_cols, ppm_data_memo


def _create_ppm_analysis_sheet(workbook, analysis_sheet_name, used_sheet_names, filing_pairs, debug_log,
                               global_element_period_values=None, seg_headers=None, included_cols=None, ppm_data=None):
    """
    PPM分析シートを生成（日本基準・IFRS共通）
    """
    from openpyxl.utils import get_column_letter
    from openpyxl.chart import BubbleChart, Reference, Series

    ppm_sheet_name = analysis_sheet_name + "_PPM分析用"
    if len(ppm_sheet_name) > 31:
        ppm_sheet_name = analysis_sheet_name[:18] + "_PPM分析用"

    debug_log(f"[PPM Analysis] Creating PPM analysis sheet: {ppm_sheet_name}")

    if ppm_sheet_name in workbook.sheetnames:
        workbook.remove(workbook[ppm_sheet_name])
    
    ppm_ws = workbook.create_sheet(title=ppm_sheet_name)
    used_sheet_names.add(ppm_sheet_name)

    if not seg_headers or not ppm_data:
        debug_log("[PPM Analysis] No data captured for PPM, skipping")
        ppm_ws.append(["データ取得エラー: PPM分析用のデータが捕捉できませんでした。"])
        return

    # 1. ヘッダー
    headers = ["勘定科目", "報告年度", "前期・当期", "会計年度"] + seg_headers
    ppm_ws.append(headers)

    # 2. 年度絞り込み
    valid_ps = []
    def _find_row(rows, ps_str, flg_str):
        for r in rows:
            if str(r[1]) == str(ps_str) and str(r[2]) == str(flg_str):
                return r
        return None

    for fp in filing_pairs:
        cp = _to_period_str(fp.get('current'))
        if not cp: continue
        if _find_row(ppm_data['sales'], cp, "当期") and _find_row(ppm_data['profit'], cp, "当期"):
            valid_ps.append(cp)
    
    valid_ps = sorted(list(set(valid_ps)))
    if len(valid_ps) > 11: valid_ps = valid_ps[-11:]
    
    if not valid_ps:
        debug_log("[PPM Analysis] No mutual data found for PPM")
        return

    # 3. 各セクション
    def _put_rows(rows_memo, target_ps, indent="　"):
        s_row = ppm_ws.max_row + 1
        for ps in target_ps:
            for fl in ["前期", "当期"]:
                d = _find_row(rows_memo, ps, fl)
                if d:
                    out = d[:]
                    out[0] = indent + str(out[0]).replace("　", "").strip()
                    ppm_ws.append(out)
                else:
                    fp = next((f for f in filing_pairs if _to_period_str(f.get('current')) == ps), {})
                    pv = _to_period_str(fp.get('prior')) if fl == "前期" else ps
                    ppm_ws.append([indent + "なし", ps, fl, pv or ""] + [""] * len(seg_headers))
        return s_row, ppm_ws.max_row

    sl_start, sl_end = _put_rows(ppm_data['sales'], valid_ps)
    ppm_ws.append([])
    pr_start, pr_end = _put_rows(ppm_data['profit'], valid_ps)
    ppm_ws.append([])

    # 増加率
    gr_start = ppm_ws.max_row + 1
    f_p = valid_ps[0]
    f_fp = next((f for f in filing_pairs if _to_period_str(f.get('current')) == f_p), {})
    b_p = _to_period_str(f_fp.get('prior'))
    ppm_ws.append(["売上高対前年増加率", b_p or "ベース", "", b_p or ""] + [""] * len(seg_headers))
    for i, ps in enumerate(valid_ps):
        p_row, c_row = sl_start + 2*i, sl_start + 2*i + 1
        ln = ["売上高対前年増加率", ps, "", ps]
        for ci in range(len(seg_headers)):
            cl = get_column_letter(5 + ci)
            ln.append(f'=IF(OR({cl}{p_row}="",{cl}{c_row}="",{cl}{p_row}=0),"",{cl}{c_row}/{cl}{p_row}-1)')
        ppm_ws.append(ln)
    gr_end = ppm_ws.max_row
    ppm_ws.append([])

    # 利益率
    mg_start = ppm_ws.max_row + 1
    ppm_ws.append(["売上高利益率", b_p or "ベース", "", b_p or ""] + [""] * len(seg_headers))
    for ci in range(len(seg_headers)):
        cl = get_column_letter(5 + ci)
        ppm_ws.cell(mg_start, 5 + ci).value = f'=IF(OR({cl}{sl_start}="",{cl}{pr_start}="",{cl}{sl_start}=0),"",{cl}{pr_start}/{cl}{sl_start})'
    for i, ps in enumerate(valid_ps):
        s_row, p_row = sl_start + 2*i + 1, pr_start + 2*i + 1
        ln = ["売上高利益率", ps, "", ps]
        for ci in range(len(seg_headers)):
            cl = get_column_letter(5 + ci)
            ln.append(f'=IF(OR({cl}{s_row}="",{cl}{p_row}="",{cl}{s_row}=0),"",{cl}{p_row}/{cl}{s_row})')
        ppm_ws.append(ln)
    mg_end = ppm_ws.max_row

    # 4. 書式・チャート
    for r in range(sl_start, pr_end + 1):
        for c in range(5, 5 + len(seg_headers)): ppm_ws.cell(r, c).number_format = r'#,##0_ ;[Red]-#,##0'
    for r in range(gr_start, mg_end + 1):
        for c in range(5, 5 + len(seg_headers)): ppm_ws.cell(r, c).number_format = '0.0%'
    ppm_ws.freeze_panes = 'E2'

    try:
        t_cols = [i for i, h in enumerate(seg_headers) if not any(kw in str(h) for kw in ["合計", "集計", "調整", "以外", "全体", "連結", "消去"])]
        if t_cols:
            chart = BubbleChart()
            chart.title = f"PPM分析 ({valid_ps[-1]})"
            chart.x_axis.title = "売上高利益率"
            chart.y_axis.title = "売上高対前年増加率"
            for ci in t_cols:
                cl = 5 + ci
                chart.series.append(Series(values=Reference(ppm_ws, min_col=cl, min_row=gr_end), 
                                           xvalues=Reference(ppm_ws, min_col=cl, min_row=mg_end), 
                                           zvalues=Reference(ppm_ws, min_col=cl, min_row=sl_end), 
                                           title=str(seg_headers[ci])))
            ppm_ws.add_chart(chart, "A" + str(mg_end + 3))
    except: pass
    debug_log(f"[PPM Analysis] Completed PPM analysis sheet")


